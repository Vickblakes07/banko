PORT=5000
# Listen on all interfaces so http://YOUR-LAN-IP:5000/health works from another device (optional)
HOST=0.0.0.0
MONGODB_URI=mongodb://127.0.0.1:27017/banko
JWT_SECRET=change-this-to-a-long-random-string-in-production
CLIENT_ORIGIN=http://localhost:3000
# Comma-separated for production + preview, e.g.:
# CLIENT_ORIGIN=https://your-app.vercel.app,https://your-app-git-main-yourname.vercel.app
#
# CORS: By default, all https://*.vercel.app origins are allowed (Vercel production + previews).
# Set CORS_STRICT=true to allow ONLY CLIENT_ORIGIN + localhost (no wildcard for *.vercel.app).
# CORS_STRICT=true
