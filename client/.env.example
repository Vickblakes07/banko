# Dev: leave unset — `/api/*` is proxied by `src/app/api/[...path]/route.ts` to http://127.0.0.1:5000.
# To point local Next at a remote API instead:
# API_INTERNAL_URL=https://banko-psp6.onrender.com

# Rare: bypass the proxy and call the API directly from the browser (needs CORS on API):
# NEXT_PUBLIC_API_URL=https://your-api.onrender.com

# If you open the site from another device (e.g. http://192.168.1.106:3000), add that hostname
# (comma-separated, no protocol) to silence Next cross-origin dev warnings:
# ALLOWED_DEV_ORIGINS=192.168.1.106
