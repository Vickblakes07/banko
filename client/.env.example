# Dev: leave unset — Next.js proxies /api → Express (see next.config.ts, API_INTERNAL_URL).
# Production (API on another host):
# NEXT_PUBLIC_API_URL=https://your-api.example.com

# If Express is not on 127.0.0.1:5000, set for the Next.js server-side rewrite only:
# API_INTERNAL_URL=http://127.0.0.1:5000

# If you open the site from another device (e.g. http://192.168.1.106:3000), add that hostname
# (comma-separated, no protocol) to silence Next cross-origin dev warnings:
# ALLOWED_DEV_ORIGINS=192.168.1.106
